# Local runtime configuration for students.
# Copy this file to .env. The defaults below are enough for local use.
# .env is git-ignored. Do not commit real secrets.

# Local dev-login does not require live Entra credentials.
ENTRA_CLIENT_ID=local-dev-client-id
ENTRA_CLIENT_SECRET=local-dev-client-secret
ENTRA_TENANT_ID=c0531484-50fa-4ff2-97df-b1f2d4810603

# App settings
JWT_SECRET_KEY=local-dev-jwt-secret-change-me
# Local runtime uses a private working copy created from the bundled seed DB.
DATABASE_URL=sqlite:///./az500_local.db
REDIRECT_URI=http://localhost:8000/auth/callback
ENVIRONMENT=local

# Production only
# KEY_VAULT_URL=https://your-key-vault.vault.azure.net/
